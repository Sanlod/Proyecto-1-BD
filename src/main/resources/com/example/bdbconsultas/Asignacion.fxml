<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<AnchorPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AsignacionController">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 0 25 0 25; -fx-border-color: #dcdde1; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <ImageView fitHeight="45.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@logo.png" />
                            </image>
                        </ImageView>
                        <Separator orientation="VERTICAL" prefHeight="30.0">
                            <HBox.margin><Insets bottom="15.0" top="15.0" /></HBox.margin>
                        </Separator>
                        <VBox alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Asignación de Casa Cuna" />
                                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Gestión de ubicación temporal para mascotas" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#cancelar" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" text="Volver al Panel" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f7f6;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" style="-fx-padding: 25;">
                            <children>

                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #3498db; -fx-border-width: 0 0 0 5;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2980b9;" text="Paso 1: Seleccionar Mascota sin Hogar" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblMascotaSeleccionada" style="-fx-text-fill: #e67e22; -fx-font-weight: bold;" text="Ninguna seleccionada" />
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tblMascotas" prefHeight="180.0">
                                            <columns>
                                                <TableColumn fx:id="colMascotaId" prefWidth="60" text="ID" />
                                                <TableColumn fx:id="colMascotaNombre" prefWidth="180" text="Nombre" />
                                                <TableColumn fx:id="colMascotaRaza" prefWidth="180" text="Raza" />
                                                <TableColumn fx:id="colMascotaTamano" prefWidth="120" text="Tamaño" />
                                                <TableColumn fx:id="colMascotaEnergia" prefWidth="100" text="ID Energía" />
                                            </columns>
                                        </TableView>
                                        <Button fx:id="btnBuscarCasas" maxWidth="Infinity" onAction="#buscarCasasCompatibles" prefHeight="40.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔍 BUSCAR CASAS COMPATIBLES" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #f1c40f; -fx-border-width: 0 0 0 5;">
                                    <children>
                                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" text="Paso 2: Elegir Casa Cuna Compatible" />
                                        <TableView fx:id="tblCasas" prefHeight="180.0">
                                            <columns>
                                                <TableColumn fx:id="colCasaId" prefWidth="80" text="ID Casa" />
                                                <TableColumn fx:id="colCasaTamanos" prefWidth="400" text="Tamaños Aceptados" />
                                                <TableColumn fx:id="colCasaDistrito" prefWidth="150" text="ID Distrito" />
                                            </columns>
                                        </TableView>
                                        <Button fx:id="btnAsignar" maxWidth="Infinity" onAction="#asignarMascota" prefHeight="45.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="✅ CONFIRMAR ASIGNACIÓN" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: #95a5a6; -fx-border-width: 0 0 0 5;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" text="Mascotas con Casa Asignada" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnQuitarAsignacion" onAction="#quitarAsignacion" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑 Quitar Asignación" />
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tblMascotasConCasa" prefHeight="180.0">
                                            <columns>
                                                <TableColumn fx:id="colMascotaConCasaId" prefWidth="60" text="ID" />
                                                <TableColumn fx:id="colMascotaConCasaNombre" prefWidth="180" text="Nombre" />
                                                <TableColumn fx:id="colMascotaConCasaRaza" prefWidth="180" text="Raza" />
                                                <TableColumn fx:id="colMascotaConCasaTamano" prefWidth="120" text="Tamaño" />
                                                <TableColumn fx:id="colMascotaConCasaEnergia" prefWidth="100" text="ID Energía" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>