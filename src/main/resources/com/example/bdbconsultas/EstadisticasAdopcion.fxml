<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="629.0" prefWidth="900" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.EstadisticasAdoptionController">

    <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

    <top>
        <VBox spacing="16">

            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Estadísticas de adopciones" />

            <!-- Filtros -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-border-color: #e0e0e0;                          -fx-border-radius: 8; -fx-background-radius: 8;                          -fx-padding: 12 16 12 16;">
                <Label text="Desde" />
                <DatePicker fx:id="dpStartDate" prefWidth="140" />
                <Label text="Hasta" />
                <DatePicker fx:id="dpEndDate" prefWidth="140" />
                <Label text="Tipo" />
                <ComboBox fx:id="cbPetType" prefWidth="140" />
                <Label text="Raza" />
                <ComboBox fx:id="cbBreed" prefWidth="140" />
                <Button onAction="#onFilter" style="-fx-cursor: hand;" text="Filtrar" />
            </HBox>

            <!-- Tarjetas resumen -->
            <HBox spacing="12">
                <VBox alignment="CENTER_LEFT" prefWidth="220" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Adopciones exitosas" />
                    <Label fx:id="lblSuccessTotal" style="-fx-font-size: 22px; -fx-text-fill: #1D9E75;" />
                    <Label fx:id="lblSuccessPct" style="-fx-font-size: 12px; -fx-text-fill: #777;" />
                </VBox>
                <VBox alignment="CENTER_LEFT" prefWidth="220" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="En espera" />
                    <Label fx:id="lblWaitingTotal" style="-fx-font-size: 22px; -fx-text-fill: #BA7517;" />
                    <Label fx:id="lblWaitingPct" style="-fx-font-size: 12px; -fx-text-fill: #777;" />
                </VBox>
                <VBox alignment="CENTER_LEFT" prefWidth="220" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Total" />
                    <Label fx:id="lblGrandTotal" style="-fx-font-size: 22px; -fx-text-fill: #534AB7;" />
                </VBox>
            </HBox>

        </VBox>
    </top>

    <center>
        <HBox spacing="16" BorderPane.alignment="CENTER">
            <HBox.margin><Insets top="16" /></HBox.margin>

            <!-- Tabla -->
            <VBox HBox.hgrow="ALWAYS">
                <TableView fx:id="tblStats" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colStatus" prefWidth="150" text="Estado" />
                        <TableColumn fx:id="colTotal" prefWidth="100" text="Cantidad" />
                        <TableColumn fx:id="colPercent" prefWidth="100" text="Porcentaje" />
                    </columns>
                </TableView>
            </VBox>

            <!-- Gráfico de pastel -->
            <PieChart fx:id="pieChart" animated="false" prefHeight="300" prefWidth="380" HBox.hgrow="ALWAYS" />

        </HBox>
    </center>
   <bottom>
      <Button mnemonicParsing="false" onAction="#switchVolver" text="Volver" BorderPane.alignment="CENTER" />
   </bottom>

</BorderPane>
