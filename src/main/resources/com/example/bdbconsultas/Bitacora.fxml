<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="1050.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.BitacoraController">
   <children>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="15.0" style="-fx-padding: 15;">
               <children>

                  <HBox alignment="CENTER_LEFT" prefHeight="65.0" style="-fx-background-color: linear-gradient(to right, #34495e, #2c3e50); -fx-background-radius: 10; -fx-padding: 15;">
                     <children>
                        <VBox>
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Bitácora de Eventos (Logs)" />
                              <Label style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;" text="Seguimiento de cambios y operaciones en la base de datos" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver" />
                     </children>
                  </HBox>

                  <HBox alignment="BOTTOM_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                     <children>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                           <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Usuario Responsable" />
                           <ComboBox fx:id="usuario" maxWidth="1.7976931348623157E308" promptText="Seleccionar..." />
                        </VBox>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                           <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Tabla Afectada" />
                           <ComboBox fx:id="tablacbx" maxWidth="1.7976931348623157E308" promptText="Todas las tablas" />
                        </VBox>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                           <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Fecha" />
                           <DatePicker fx:id="fecha" maxWidth="1.7976931348623157E308" />
                        </VBox>
                        <Button onAction="#buscar" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="🔍 Consultar" />
                     </children>
                  </HBox>

                  <VBox spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;" VBox.vgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Historial de Transacciones" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label style="-fx-text-fill: #16a085; -fx-font-size: 11px; -fx-font-weight: bold;" text="Visualización Detallada" />
                           </children>
                        </HBox>

                        <TableView fx:id="tabla" prefHeight="400.0" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn prefWidth="150.0" minWidth="130.0" text="FECHA / HORA" />
                              <TableColumn prefWidth="100.0" minWidth="80.0" text="USUARIO" />
                              <TableColumn prefWidth="100.0" minWidth="90.0" text="OPERACIÓN" />
                              <TableColumn prefWidth="120.0" minWidth="100.0" text="TABLA" />
                              <TableColumn prefWidth="450.0" minWidth="300.0" text="DETALLE DEL CAMBIO" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>