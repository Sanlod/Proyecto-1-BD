<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.SinAdoptarController">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="15.0" style="-fx-padding: 15;">
                    <children>

                        <HBox alignment="CENTER_LEFT" prefHeight="65.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15;">
                            <children>
                                <VBox>
                                    <children>
                                        <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Análisis de Mascotas Sin Adoptar" />
                                        <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" text="Filtros avanzados por tiempo de estancia y características" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver" />
                            </children>
                        </HBox>

                        <HBox alignment="BOTTOM_LEFT" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                            <children>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Meses sin adoptar" />
                                    <Spinner fx:id="meses" prefWidth="100.0" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Tipo" />
                                    <ComboBox fx:id="tipo" onAction="#actualizarRazas" prefWidth="130.0" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Raza" />
                                    <ComboBox fx:id="raza" prefWidth="150.0" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Color" />
                                    <ComboBox fx:id="color" prefWidth="120.0" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Edad" />
                                    <ComboBox fx:id="edad" prefWidth="120.0" />
                                </VBox>
                                <Button onAction="#buscar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="🔍 Buscar" />
                            </children>
                        </HBox>

                        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                            <children>

                                <VBox prefWidth="500.0" spacing="15.0">
                                    <children>
                                        <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Detalle de Mascotas" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="total" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-padding: 2 10; -fx-background-radius: 10;" text="0" />
                                                </HBox>
                                                <TableView fx:id="mascotasTable" prefHeight="250.0" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn minWidth="120.0" prefWidth="150.0" text="Nombre" />
                                                        <TableColumn minWidth="100.0" prefWidth="120.0" text="Chip" />
                                                        <TableColumn minWidth="120.0" prefWidth="150.0" text="Fecha Ingreso" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Resumen Estadístico" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="totalEstadistica" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 2 10; -fx-background-radius: 10;" text="0" />
                                                </HBox>
                                                <TableView fx:id="tablaEstadistica" prefHeight="200.0" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn minWidth="150.0" prefWidth="250.0" text="Categoría" />
                                                        <TableColumn minWidth="80.0" prefWidth="100.0" text="Cantidad" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" text="Distribución Visual" />
                                        <PieChart fx:id="pieChart" minHeight="300.0" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>