<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="900" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.EstadisticasMatchesController">

    <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

    <top>
        <VBox spacing="16">

            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Estadísticas de matches" />

            <!-- Tarjetas resumen -->
            <HBox spacing="12">
                <VBox alignment="CENTER_LEFT" prefWidth="220" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Total de matches" />
                    <Label fx:id="lblTotalRecords" style="-fx-font-size: 22px; -fx-text-fill: #534AB7;" />
                </VBox>
                <VBox alignment="CENTER_LEFT" prefWidth="220" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Promedio de similitud" />
                    <Label fx:id="lblOverallAvg" style="-fx-font-size: 22px; -fx-text-fill: #1D9E75;" />
                </VBox>
            </HBox>

        </VBox>
    </top>

    <center>
        <HBox spacing="16" BorderPane.alignment="CENTER">
            <HBox.margin><Insets top="16" /></HBox.margin>

            <!-- Tabla -->
            <VBox HBox.hgrow="ALWAYS">
                <TableView fx:id="tblStats" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colStatus" prefWidth="120" text="Estado" />
                        <TableColumn fx:id="colTotal" prefWidth="90" text="Cantidad" />
                        <TableColumn fx:id="colAvgSimilarity" prefWidth="140" text="Similitud promedio" />
                        <TableColumn fx:id="colPercent" prefWidth="100" text="Porcentaje" />
                    </columns>
                </TableView>
            </VBox>

            <!-- Gráfico -->
            <PieChart fx:id="pieChart" animated="false" prefHeight="300" prefWidth="380" HBox.hgrow="ALWAYS" />

        </HBox>
    </center>
   <bottom>
      <Button mnemonicParsing="false" onAction="#switchVolver" text="Volver" BorderPane.alignment="CENTER" />
   </bottom>

</BorderPane>
