<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="650.0" prefWidth="875.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bdbconsultas.AdoptarController">
   <children>

      <Button fx:id="btnVolver" layoutX="815.0" layoutY="10.0"
              text="Volver" onAction="#onVolver"/>

      <Text layoutX="30.0" layoutY="45.0" text="Mascota:"/>
      <ComboBox fx:id="cmbMascota" layoutX="100.0" layoutY="28.0" prefWidth="200.0"/>

      <Text layoutX="320.0" layoutY="45.0" text="Adoptante:"/>
      <ComboBox fx:id="cmbAdoptante" layoutX="390.0" layoutY="28.0" prefWidth="200.0"/>

      <Text layoutX="30.0" layoutY="85.0" text="Notas:"/>
      <TextArea fx:id="txtNotas" layoutX="30.0" layoutY="90.0"
                prefHeight="60.0" prefWidth="400.0"/>

      <!-- Fotos req. f -->
      <Text layoutX="30.0" layoutY="168.0" text="Foto con mascota:"/>
      <Button fx:id="btnFoto" layoutX="150.0" layoutY="152.0"
              text="Seleccionar" onAction="#onSeleccionarFoto"/>
      <Label fx:id="lblFoto" layoutX="260.0" layoutY="157.0" text="Sin foto"/>

      <Text layoutX="30.0" layoutY="198.0" text="Foto nueva vida:"/>
      <Button fx:id="btnFotoNueva" layoutX="150.0" layoutY="182.0"
              text="Seleccionar" onAction="#onSeleccionarFotoNueva"/>
      <Label fx:id="lblFotoNueva" layoutX="260.0" layoutY="187.0" text="Sin foto"/>

      <!-- Formulario parametrizable req. o -->
      <Text layoutX="30.0" layoutY="222.0" text="Formulario de solicitud:"/>
      <ScrollPane layoutX="30.0" layoutY="228.0" prefHeight="340.0" prefWidth="840.0"
                  fitToWidth="true">
         <content>
            <VBox fx:id="vboxPreguntas" spacing="15.0" style="-fx-padding: 10;"/>
         </content>
      </ScrollPane>

      <Button fx:id="btnRegistrar" layoutX="740.0" layoutY="585.0"
              text="Registrar adopción" onAction="#onRegistrar"/>

   </children>
</AnchorPane>