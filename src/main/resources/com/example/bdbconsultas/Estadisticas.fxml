<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.EstadisticasController">

   <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>

   <top>
      <VBox spacing="16" BorderPane.alignment="CENTER">

         <!-- Título -->
         <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Estadísticas de mascotas" />

         <!-- Barra de filtros -->
         <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-border-color: #e0e0e0;                          -fx-border-radius: 8; -fx-background-radius: 8;                          -fx-padding: 12 16 12 16;">
            <Label text="Desde" />
            <DatePicker fx:id="dpStartDate" prefWidth="140" />
            <Label text="Hasta" />
            <DatePicker fx:id="dpEndDate" prefWidth="140" />
            <Button onAction="#onFilter" style="-fx-cursor: hand;" text="Filtrar" />
         </HBox>

         <!-- Tarjetas de totales por estado -->
         <HBox spacing="12">
            <VBox fx:id="cardLost" alignment="CENTER_LEFT" prefWidth="200" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
               <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Perdidas" />
               <Label fx:id="lblLostTotal" style="-fx-font-size: 22px; -fx-text-fill: #E24B4A;" />
               <Label fx:id="lblLostPct" style="-fx-font-size: 12px; -fx-text-fill: #777;" />
            </VBox>
            <VBox fx:id="cardFound" alignment="CENTER_LEFT" prefWidth="200" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
               <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Encontradas" />
               <Label fx:id="lblFoundTotal" style="-fx-font-size: 22px; -fx-text-fill: #1D9E75;" />
               <Label fx:id="lblFoundPct" style="-fx-font-size: 12px; -fx-text-fill: #777;" />
            </VBox>
            <VBox fx:id="cardAdopted" alignment="CENTER_LEFT" prefWidth="200" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
               <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="Adoptadas" />
               <Label fx:id="lblAdoptedTotal" style="-fx-font-size: 22px; -fx-text-fill: #378ADD;" />
               <Label fx:id="lblAdoptedPct" style="-fx-font-size: 12px; -fx-text-fill: #777;" />
            </VBox>
            <VBox fx:id="cardInAdoption" alignment="CENTER_LEFT" prefWidth="200" style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;                              -fx-padding: 14 16 14 16;">
               <Label style="-fx-font-size: 12px; -fx-text-fill: #777;" text="En adopción" />
               <Label fx:id="lblInAdoptionTotal" style="-fx-font-size: 22px; -fx-text-fill: #BA7517;" />
               <Label fx:id="lblInAdoptionPct" style="-fx-font-size: 12px; -fx-text-fill: #777;" />
            </VBox>
         </HBox>

      </VBox>
   </top>

   <!-- Tabla + Gráfico -->
   <center>
      <HBox spacing="16" BorderPane.alignment="CENTER">
         <HBox.margin><Insets top="16" /></HBox.margin>

         <!-- Tabla detalle -->
         <VBox spacing="8" HBox.hgrow="ALWAYS">
            <TableView fx:id="tblStats" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colType" prefWidth="120" text="Tipo" />
                  <TableColumn fx:id="colState" prefWidth="120" text="Estado" />
                  <TableColumn fx:id="colTotal" prefWidth="90" text="Cantidad" />
                  <TableColumn fx:id="colPercent" prefWidth="80" text="Porcentaje" />
               </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
               <Label style="-fx-font-size: 13px; -fx-text-fill: #777;" text="Total general: " />
               <Label fx:id="lblGrandTotal" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
            </HBox>
         </VBox>

         <!-- Gráfico de barras -->
         <BarChart fx:id="barChart" animated="false" prefHeight="340" prefWidth="380" HBox.hgrow="ALWAYS">
            <xAxis>
               <CategoryAxis label="Tipo de mascota" fx:id="xAxis" />
            </xAxis>
            <yAxis>
               <NumberAxis fx:id="yAxis" label="Cantidad" />
            </yAxis>
         </BarChart>

      </HBox>
   </center>
   <bottom>
      <Button mnemonicParsing="false" onAction="#switchVolver" text="Volver" BorderPane.alignment="CENTER" />
   </bottom>

</BorderPane>
